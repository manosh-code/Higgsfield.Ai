// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id              String      @id     @default(uuid())
  username        String      @unique
  password        String
  avatars         Avatar[]
  avatarVideos    AvatarVideo[]
}

model Avatar {
  id             String     @id   @default(uuid())
  userId         String
  name           String
  avatarImage    AvatarImage[]
  avatarVideoReference    AvatarVideoReference[]
  user           user       @relation(fields: [userId], reference: [id])

}

model AvatarImage {
  id           String    @id       @default(uuid())
  avatarId     String
  type         AvatarImageType
  url          String
  avatar       Avatar     @relation(fields: [avatarId], reference: [id])

}

enum AvatarImageType {
  User 
  model
}

model AvatarVideo {
  id            String      @id      @default(uuid())
  userId        String
  prompt        String
  startFrame    String?
  endFrame      String?
  duration      Int
  width         Int
  height        Int
  status        AvatarVideoStatus
  avatarVideoReference      AvatarVideoReference[]
  user          User        @relation(fields:  [userId], reference: [id])

}

model AvatarVideoReference {
  id                String       @id       @default(uuid())
  avatarVideoId     String
  avatarId          String
  avatar            Avatar       @relation(fields: [avatarId], reference: [id])
  avatarVideo       AvatarVideo  @relation(fields:  [avatarVideoId], reference: [id])
}

enum AvatarVideoStatus {
  Pending
  Done 
  Error
}